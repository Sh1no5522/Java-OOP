#include<iostream>

using namespace std;

int main(){
    int c;
    int n , d = -1215752192;
    cin >> n;
    int arr[n], i;
    for(i=0; i<n; i++){
        cin>>arr[i];
    }
    for(i=0; i<n; i++){
        if(arr[i] > d){
            d = arr[i];
            c = i + 1;
        }
    }
    cout << c;
    return 0;
    
}